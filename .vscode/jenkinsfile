pipeline {
    agent any

    environment {
        DOCKERHUB_CREDEENTIALS = 'dockerhub-creds'
        DOCKERHUB_REPO = 'manisharchana'
        KUBE_CONFIG = 'kubeconfig_aws'
    }
    stages {
            stage('Clone Repo') {
            steps {
                git 'https://github.com/mntforever/docker-samples-voting-app.git', branch: 'main'
            }
        }
        
        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig_aws', variable: 'KUBECONFIG_FILE')]) {
                     sh '''
                         export KUBECONFIG=/etc/kubernetes/admin.conf
                            kubectl get nodes
                        '''
}
                }
            }
        }


        stage('Verify Deployment') {
            steps {
                withCredentials([file(credentialsId: KUBE_CONFIG, variable: 'KUBECONFIG')]) {
                    sh '''
                        kubectl get pods
                        kubectl get svc
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful!'
        }
        failure {
            echo 'Pipeline Failed!'
        }
 }